# CommandClaw MCP Gateway — Environment Variables
#
# Copy to .env:  cp .env.example .env
# Or run:        make setup       (generates .env with a random encryption seed)
#
# These env vars OVERRIDE values in ~/.commandclaw/mcp.json.
# Use the JSON file for structural config (servers, access rules).
# Use env vars for deployment-specific overrides and secrets.

# ─── Gateway ──────────────────────────────────────────────
COMMANDCLAW_GATEWAY__HOST=127.0.0.1
COMMANDCLAW_GATEWAY__PORT=8420
COMMANDCLAW_GATEWAY__ENCRYPTION_SEED=CHANGE-ME-TO-A-RANDOM-STRING
COMMANDCLAW_GATEWAY__KEY_ROTATION_INTERVAL_SECONDS=3600
COMMANDCLAW_GATEWAY__OVERLAP_WINDOW_SECONDS=300

# ─── Redis ────────────────────────────────────────────────
COMMANDCLAW_REDIS__URL=redis://localhost:6379/0

# ─── Cerbos PDP ──────────────────────────────────────────
COMMANDCLAW_CERBOS__HOST=localhost
COMMANDCLAW_CERBOS__PORT=3592
COMMANDCLAW_CERBOS__TLS=false

# ─── Observability ────────────────────────────────────────
COMMANDCLAW_OBSERVABILITY__OTLP_ENDPOINT=http://localhost:4317
COMMANDCLAW_OBSERVABILITY__TRACES_SAMPLER_ARG=0.1
COMMANDCLAW_OBSERVABILITY__INTERNAL_TRACING=false

# ─── Docker Compose overrides ─────────────────────────────
# These are set automatically by docker-compose.yml.
# Uncomment only if you need to override the compose defaults.
#
# COMMANDCLAW_GATEWAY__HOST=0.0.0.0
# COMMANDCLAW_GATEWAY__ALLOW_NON_LOOPBACK=true
# COMMANDCLAW_REDIS__URL=redis://redis:6379/0
# COMMANDCLAW_CERBOS__HOST=cerbos
# COMMANDCLAW_CERBOS__ALLOW_PLAINTEXT=true
